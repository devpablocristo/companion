COMPOSE_PROJECT_NAME=companion

# Puertos (host)
COMPANION_PORT=18085
COMPANION_CONSOLE_PORT=13002
COMPANION_POSTGRES_PORT=15435

# API keys del propio servicio companion
COMPANION_ADMIN_API_KEY=companion-admin-dev-key

# Auth humano opcional (OIDC/JWKS, ej. Clerk)
NEXUS_AUTH_ISSUER_URL=
NEXUS_AUTH_AUDIENCE=

# Dependencia: Nexus Governance (proyecto separado)
NEXUS_BASE_URL=http://host.docker.internal:18084
NEXUS_API_KEY=nexus-admin-dev-key
COMPANION_NEXUS_SYNC_INTERVAL_SEC=30

# Pymes Core (watchers proactivos)
PYMES_BASE_URL=
PYMES_API_KEY=
COMPANION_WATCHER_INTERVAL_SEC=0

# LLM (echo, ollama, anthropic, gemini)
NEXUS_LLM_PROVIDER=echo
NEXUS_LLM_API_KEY=
NEXUS_LLM_MODEL=qwen2.5:3b

# Clerk auth (Console browser)
VITE_CLERK_PUBLISHABLE_KEY=
