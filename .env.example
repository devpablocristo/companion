COMPOSE_PROJECT_NAME=companion

# Puertos (host)
COMPANION_PORT=18085
COMPANION_CONSOLE_PORT=13002
COMPANION_POSTGRES_PORT=15435

# API keys del propio servicio companion
COMPANION_ADMIN_API_KEY=companion-admin-dev-key

# Auth humano opcional (OIDC/JWKS, ej. Clerk)
COMPANION_AUTH_ISSUER_URL=
COMPANION_AUTH_AUDIENCE=

# Dependencia: Nexus Governance (proyecto separado)
GOVERNANCE_BASE_URL=http://host.docker.internal:18084
# Mismo valor que GOVERNANCE_ADMIN_API_KEY en nexus/.env (dev: governance-admin-dev-key).
GOVERNANCE_API_KEY=governance-admin-dev-key
COMPANION_GOVERNANCE_SYNC_INTERVAL_SEC=30

# Pymes Core (watchers proactivos)
PYMES_BASE_URL=
PYMES_API_KEY=
COMPANION_WATCHER_INTERVAL_SEC=0

# LLM (echo, ollama, anthropic, gemini)
COMPANION_LLM_PROVIDER=echo
COMPANION_LLM_API_KEY=
COMPANION_LLM_MODEL=qwen2.5:3b

# Clerk auth (Console browser)
VITE_CLERK_PUBLISHABLE_KEY=
