map $host $governance_proxy_api_key {
    default "";
    localhost "${GOVERNANCE_PROXY_API_KEY}";
    127.0.0.1 "${GOVERNANCE_PROXY_API_KEY}";
    ::1 "${GOVERNANCE_PROXY_API_KEY}";
}

map $host $companion_proxy_api_key {
    default "";
    localhost "${COMPANION_PROXY_API_KEY}";
    127.0.0.1 "${COMPANION_PROXY_API_KEY}";
    ::1 "${COMPANION_PROXY_API_KEY}";
}

# DNS resolver para resolver upstreams dinámicamente.
resolver 127.0.0.11 ipv6=off valid=10s;

server {
    listen 80;
    root /usr/share/nginx/html;
    index index.html;

    # SPA: todas las rutas al index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Companion backend (intra-red docker-compose)
    location /companion/ {
        proxy_pass http://companion:8080/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-API-Key $companion_proxy_api_key;
    }

    # Nexus governance (externo: vive en otro proyecto).
    # Por defecto usa host.docker.internal:18084. Para producción ajustar a
    # la URL real de Nexus governance antes de levantar el container.
    location /v1/ {
        set $governance_upstream "http://host.docker.internal:18084";
        proxy_pass $governance_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-API-Key $governance_proxy_api_key;
    }

    # Healthz: redirige a Companion (su propio readyz). Governance gestiona el suyo.
    location /healthz {
        proxy_pass http://companion:8080;
    }

    location /readyz {
        proxy_pass http://companion:8080;
    }
}
